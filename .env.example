# Copy to .env for local dev (`cp .env.example .env`), then fill in values.
# For Railway: set these in Project → Variables (do NOT commit a real .env).
#
# Locally, the server does NOT auto-load .env. Run with:
#   DASHBOARD_PASSWORD=... META_TOKEN=... META_AD_ACCOUNT=act_... npm start
# or `export` them in your shell first.

# ----- Access password (REQUIRED in production) -----
# Two options. Pick ONE and unset the other.
#
# OPTION A (preferred) — bcrypt hash. Generate with:
#     npm run hash-password
# Paste the resulting $2a$12$... string here. Cost factor must be ≥ 10;
# the server refuses to start otherwise.
DASHBOARD_PASSWORD_HASH=
#
# OPTION B (legacy / quick setup) — plaintext password. Falls back to this
# when no hash is set. Logs a warning at boot. Switch to OPTION A as soon
# as you can. 16+ chars recommended.
DASHBOARD_PASSWORD=

# ----- Meta Marketing API (preferred — live data) -----
# Long-lived access token with ads_read on the target ad account.
META_TOKEN=
# Ad account id, including the "act_" prefix.
META_AD_ACCOUNT=act_XXXXXXXXXXXX
# Optional. Any Graph API date_preset value (last_7d, last_14d, last_30d, ...).
META_DATE_PRESET=last_7d
# Optional. Comma-separated campaign ids to limit the insights query to.
# Leave empty to pull every campaign in the ad account.
# Example: META_CAMPAIGN_IDS=120243586878400130,120243586878400131
META_CAMPAIGN_IDS=

# ----- Google Sheets fallback (used only if META_TOKEN is not set) -----
META_CSV_URL=https://docs.google.com/spreadsheets/d/e/<META_ID>/pub?gid=0&single=true&output=csv

# ----- Creative links sheet (always required) -----
LINKS_CSV_URL=https://docs.google.com/spreadsheets/d/e/<LINKS_ID>/pub?gid=0&single=true&output=csv

# Google Drive API key (used to resolve folder links → playable videos and
# to power the Diagnose creative links tool). Create one at:
# https://console.cloud.google.com/apis/credentials  →  Create credentials  →  API key
# Enable: APIs & Services → Library → Google Drive API.
DRIVE_API_KEY=

# ----- AI features (optional — auto-fills Settings for every user) -----
# When set, every signed-in dashboard user gets Gemini wired up
# automatically without pasting a key. Sent over the authed /config.json
# only. Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# ----- Analysis history (optional — persists every analysis to a sheet) -----
# When set together with GOOGLE_CREDENTIALS_JSON, the dashboard:
#   - Appends every completed AI analysis to an "Analysis Log" tab on this
#     sheet (created automatically on first write).
#   - Renders the saved analysis instantly when you re-open the same ad,
#     no Gemini call needed.
#   - Injects the 3 most recent winners (score >= 4) into new analysis
#     prompts so Gemini compares the current ad against your real history.
# Setup: create a sheet, share it with the service account email as Editor,
# then put its id (the long string between /d/ and /edit in the URL) here.
ANALYSIS_SHEET_ID=

# Port the Node server listens on. Railway sets this automatically.
PORT=3000
